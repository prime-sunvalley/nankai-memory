    const contentDiv = document.getElementById('content');

    function renderNode(index) {
        isTransitioning = true;
        contentDiv.innerHTML = '';
        const node = nodes[index];

        const sceneDiv = document.createElement('div');
        sceneDiv.className = 'scene-title';
        sceneDiv.innerText = node.scene;
        
        const textDiv = document.createElement('div');
        textDiv.className = 'text-block';
        textDiv.innerText = node.text;

        const optionsDiv = document.createElement('div');
        optionsDiv.className = 'options text-block';
        optionsDiv.style.animationDelay = '0.5s';
        
        node.options.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.innerText = opt.label;
            // 最后一题的选项不计分，直接触发结算
            if(index === nodes.length - 1) {
                btn.onclick = () => showResult();
            } else {
                btn.onclick = () => handleChoice(opt.axis);
            }
            optionsDiv.appendChild(btn);
        });

        contentDiv.appendChild(sceneDiv);
        contentDiv.appendChild(textDiv);
        contentDiv.appendChild(optionsDiv);
        
        setTimeout(() => isTransitioning = false, 1500);
    }

    function handleChoice(axis) {
        if (isTransitioning) return;
        scores[axis]++;
        currentStep++;
        renderNode(currentStep);
    }

    function showResult() {
        contentDiv.innerHTML = '';
        
        let maxAxis = 'A';
        let maxScore = -1;
        for (const [axis, score] of Object.entries(scores)) {
            if (score > maxScore) {
                maxScore = score;
                maxAxis = axis;
            }
        }
        
        const finalResult = results[maxAxis];

        contentDiv.innerHTML = `
            <div class="text-block" style="animation-duration: 2s;">
                <div class="report-title">${finalResult.title}</div>
                <div class="report-desc">${finalResult.desc}</div>
            </div>
            <div class="options text-block" style="animation-delay: 1.5s; margin-top: 50px;">
                <button class="option-btn" style="text-align: center; color: var(--highlight); border-color: var(--highlight); letter-spacing: 2px;" onclick="location.reload()">如果校钟重鸣，回到那年九月，弥补这场遗憾</button>
            </div>
        `;
    }

    const introScreen = document.getElementById('intro-screen');
    const bgMusic = document.getElementById('bg-music');
    const introText = document.querySelector('.intro-text');

    introScreen.addEventListener('click', () => {
        introText.innerText = "[ 记忆链路接通中... ]";
        
        const playPromise = bgMusic.play();

        if (playPromise !== undefined) {
            playPromise.then(() => {
                introScreen.style.opacity = '0';
                setTimeout(() => {
                    introScreen.style.display = 'none';
                    renderNode(0);
                }, 2000);
            }).catch(error => {
                console.warn("听觉维度的唤醒受限，已转为静默推演", error);
                introScreen.style.opacity = '0';
                setTimeout(() => {
                    introScreen.style.display = 'none';
                    renderNode(0);
                }, 2000);
            });
        }
    });

</script>
